<form onsubmit="return false">
	<search>
		<label>
			<svg webc:keep xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
				<path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.637 10.637Z" />
			</svg>
			<input type="text" id="pub-search" placeholder="Search title, author, or venue…">
			<button type="button" id="clear-search-btn" aria-label="Clear search" hidden>&times;</button>
		</label>
		<button type="button" id="toggle-all-pubs" class="btn-outline">Expand All</button>
	</search>

	<fieldset>
		<label>Topic
			<select id="filter-topic">
				<option value="all">All Topics</option>
				<option value="logging">Logging &amp; Log Intelligence</option>
				<option value="performance">Performance Engineering</option>
				<option value="testing">Software Testing &amp; DevOps</option>
				<option value="api">API Usability &amp; Evolution</option>
				<option value="ai-llm">AI &amp; LLMs for SE</option>
				<option value="other">Other Topics</option>
			</select>
		</label>
		<label>Type
			<select id="filter-type">
				<option value="all">All Types</option>
				<option value="journal">Journal Papers</option>
				<option value="conference">Conference Papers</option>
			</select>
		</label>
		<label>Year
			<select id="filter-year">
				<option value="all">All Years</option>
			</select>
		</label>
		<label>Venue
			<select id="filter-venue">
				<option value="all">All Venues</option>
			</select>
		</label>
	</fieldset>

	<div>
		<output id="pub-counts">Showing all publications</output>
		<button type="button" id="reset-filters" class="btn-text" hidden>Clear all filters</button>
	</div>
</form>
