<div id="pub-list" aria-live="polite"></div>
<script type="application/json" id="pub-data" webc:keep @html="JSON.stringify($data.publications).replace(/</g, '\\u003c')"></script>

<style webc:scoped>
	:host {
		display: block;
		max-width: var(--content-wide);
		margin-inline: auto;
	}

	.pub-year {
		margin-bottom: 2rem;
		background-color: var(--color-bg-surface);
		border: 1px solid var(--color-card-border);
		border-radius: var(--radius);
		overflow: hidden;
		box-shadow: var(--card-shadow);
		transition: border-color var(--transition);
	}

	.pub-year:hover {
		border-color: var(--color-primary);
	}

	.year-header {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		cursor: pointer;
		padding: 1.25rem 1.75rem;
		list-style: none;
		user-select: none;
	}

	.year-header::-webkit-details-marker {
		display: none;
	}

	.year-header h3 {
		margin: 0;
		font-size: 1.45rem;
		font-weight: 700;
		color: var(--color-text);
	}

	.year-header::after {
		content: "";
		margin-left: auto;
		width: 8px;
		height: 8px;
		border-right: 2px solid var(--color-text-muted);
		border-bottom: 2px solid var(--color-text-muted);
		transform: rotate(-45deg);
		transition: transform var(--transition);
	}

	.pub-year[open] .year-header::after {
		transform: rotate(45deg);
	}

	.pub-year[open] .year-header {
		border-bottom: 1px solid var(--color-border);
	}

	.pub-group {
		margin-bottom: 1.75rem;
	}

	.pub-year[open] .pub-group {
		padding-inline: 1.75rem;
	}

	.pub-year[open] .pub-group:first-of-type {
		padding-top: 1.5rem;
	}

	.pub-year[open] .pub-group:last-of-type {
		padding-bottom: 1.75rem;
		margin-bottom: 0;
	}

	.pub-group h4 {
		font-family: var(--font-heading);
		font-size: 1rem;
		font-weight: 700;
		color: var(--color-primary);
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin-bottom: 1rem;
		padding-bottom: 0.4rem;
		border-bottom: 1px solid var(--color-border);
	}

	.pub-entry {
		margin-bottom: 1.25rem;
		padding: 0.25rem 0 0.25rem 1.25rem;
		border-left: 3px solid var(--color-border);
		transition: border-color var(--transition-fast);
	}

	.pub-entry:last-child {
		margin-bottom: 0;
	}

	.pub-entry:hover {
		border-color: var(--color-primary);
	}

	.pub-entry .title {
		font-weight: 600;
		color: var(--color-text);
	}

	.pub-entry .authors {
		color: var(--color-text);
	}

	.pub-entry em {
		font-style: italic;
		color: var(--color-text-muted);
	}

	.pub-entry.hidden,
	.pub-group.hidden,
	.pub-year.hidden {
		display: none !important;
	}
</style>

<script>
	(() => {
		const dataEl = document.getElementById("pub-data");
		const listEl = document.getElementById("pub-list");
		if (!dataEl || !listEl) return;

		const raw = JSON.parse(dataEl.textContent);
		const PI = "Weiyi Shang";

		const VENUE_RULES = [
			[/methodology|tosem/i, "TOSEM"],
			[/transactions on software engineering|\btse\b/i, "TSE"],
			[/empirical software engineering and measurement|\besem\b/i, "ESEM"],
			[/empirical software engineering|\bemse\b/i, "EMSE"],
			[/journal of systems and software|\bjss\b/i, "JSS"],
			[/information and software technology|\bist\b/i, "IST"],
			[/computing surveys|\bcsur\b/i, "CSUR"],
			[/ieee software/i, "IEEE Software"],
			[/software maintenance|icsme/i, "ICSME"],
			[/program comprehension|icpc/i, "ICPC"],
			[/analysis, evolution|reengineering|saner/i, "SANER"],
			[/mining software repositories|\bmsr\b/i, "MSR"],
			[/performance engineering|icpe/i, "ICPE"],
			[/automated software engineering|\base\b/i, "ASE"],
			[/foundations of software engineering|\besec\b|\bfse\b/i, "FSE"],
			[/international conference on software engineering|icse/i, "ICSE"],
			[/software testing|verification and validation|icst/i, "ICST"],
			[/software reliability|issre/i, "ISSRE"],
			[/internetware/i, "Internetware"],
			[/neural information processing|neurips/i, "NeurIPS"],
			[/ieee access/i, "IEEE Access"],
		];
		const TOPIC_RULES = [
			["logging", /\blog\b|logs|logging|observability|telemetry/i],
			["performance", /performance|load test|microbenchmark|\bjit\b|regression|energy|efficien|benchmark/i],
			["testing", /\btest|flaky|devops|\bci\b|quality assurance|\bgui\b|fuzz/i],
			["api", /\bapi\b|workaround/i],
			["ai-llm", /\bllm\b|language model|machine learning|deep learning|neural|\bai\b|\bgpt\b|code generation/i],
		];

		const venueOf = (c) => (VENUE_RULES.find(([re]) => re.test(c)) || [, "Other"])[1];
		const topicsOf = (t) => {
			const m = TOPIC_RULES.filter(([, re]) => re.test(t)).map(([k]) => k);
			return m.length ? m : ["other"];
		};
		const authorsHtml = (a) =>
			(a || [])
				.map((x) => `${x.given || ""} ${x.family || ""}`.trim())
				.map((n) => (n === PI ? `<strong>${n}</strong>` : n))
				.join(", ");
		const enrich = (e, type) => {
			const c = e["container-title"] || "";
			const y = e.issued && e.issued["date-parts"] && e.issued["date-parts"][0] && e.issued["date-parts"][0][0];
			return {
				title: e.title || "",
				authors: authorsHtml(e.author),
				container: c,
				venue: venueOf(c),
				type,
				topics: topicsOf(`${e.title || ""} ${c}`),
				year: y != null ? String(y) : "",
			};
		};
		const esc = (s) => String(s).replace(/[&<>]/g, (ch) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;" }[ch]));

		const entries = [
			...(raw.journal || []).map((e) => enrich(e, "journal")),
			...(raw.conference || []).map((e) => enrich(e, "conference")),
		];
		const years = [...new Set(entries.map((e) => e.year).filter(Boolean))].sort((a, b) => b - a);
		const GROUPS = [["journal", "Journal Papers"], ["conference", "Conference Papers"]];

		listEl.innerHTML = years
			.map((year, yi) => {
				const groups = GROUPS.map(([type, label]) => {
					const items = entries.filter((e) => e.year === year && e.type === type);
					if (!items.length) return "";
					const rows = items
						.map(
							(it) =>
								`<div class="pub-entry" data-year="${it.year}" data-type="${it.type}" data-venue="${esc(it.venue)}" data-topic="${it.topics.join(" ")}"><p><span class="authors">${it.authors}</span>. <span class="title">${esc(it.title)}</span>. <em>${esc(it.container)}</em>.</p></div>`
						)
						.join("");
					return `<div class="pub-group"><h4>${label}</h4>${rows}</div>`;
				}).join("");
				return `<details class="pub-year"${yi === 0 ? " open" : ""}><summary class="year-header"><h3>${year}</h3></summary>${groups}</details>`;
			})
			.join("");

		// Populate Year + Venue dropdowns
		const fYear = document.getElementById("filter-year");
		const fVenue = document.getElementById("filter-venue");
		years.forEach((y) => fYear && fYear.appendChild(new Option(y, y)));
		[...new Set(entries.map((e) => e.venue))]
			.sort((a, b) => (a === "Other" ? 1 : b === "Other" ? -1 : a.localeCompare(b)))
			.forEach((v) => fVenue && fVenue.appendChild(new Option(v, v)));

		// Filtering
		const search = document.getElementById("pub-search");
		const clearBtn = document.getElementById("clear-search-btn");
		const fTopic = document.getElementById("filter-topic");
		const fType = document.getElementById("filter-type");
		const resetBtn = document.getElementById("reset-filters");
		const counts = document.getElementById("pub-counts");
		const toggleAll = document.getElementById("toggle-all-pubs");
		const total = entries.length;
		if (counts) counts.textContent = `Showing all ${total} publications`;

		function applyFilter() {
			const q = (search?.value || "").toLowerCase().trim();
			const topic = fTopic?.value || "all";
			const type = fType?.value || "all";
			const year = fYear?.value || "all";
			const venue = fVenue?.value || "all";
			let visible = 0;

			listEl.querySelectorAll(".pub-entry").forEach((el) => {
				const matches =
					(!q || el.textContent.toLowerCase().includes(q)) &&
					(topic === "all" || (el.dataset.topic || "").split(" ").includes(topic)) &&
					(type === "all" || el.dataset.type === type) &&
					(year === "all" || el.dataset.year === year) &&
					(venue === "all" || el.dataset.venue === venue);
				el.classList.toggle("hidden", !matches);
				if (matches) visible++;
			});

			listEl.querySelectorAll(".pub-group").forEach((g) =>
				g.classList.toggle("hidden", !g.querySelector(".pub-entry:not(.hidden)"))
			);
			const active = q || topic !== "all" || type !== "all" || year !== "all" || venue !== "all";
			listEl.querySelectorAll(".pub-year").forEach((d) => {
				const has = d.querySelector(".pub-entry:not(.hidden)");
				d.classList.toggle("hidden", !has);
				if (has && active) d.open = true;
			});

			if (counts) counts.textContent = `Showing ${visible} of ${total} publications`;
			if (clearBtn) clearBtn.hidden = !q;
			if (resetBtn) resetBtn.hidden = !active;
		}

		[search, fTopic, fType, fYear, fVenue].forEach(
			(el) => el && el.addEventListener(el.tagName === "INPUT" ? "input" : "change", applyFilter)
		);
		clearBtn?.addEventListener("click", () => {
			if (search) search.value = "";
			applyFilter();
			search?.focus();
		});
		resetBtn?.addEventListener("click", () => {
			if (search) search.value = "";
			[fTopic, fType, fYear, fVenue].forEach((s) => s && (s.value = "all"));
			applyFilter();
		});
		toggleAll?.addEventListener("click", () => {
			const vis = [...listEl.querySelectorAll(".pub-year:not(.hidden)")];
			const allOpen = vis.every((d) => d.open);
			vis.forEach((d) => (d.open = !allOpen));
			toggleAll.textContent = allOpen ? "Expand All" : "Collapse All";
		});
	})();
</script>
